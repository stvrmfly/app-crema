# Crema backend configuration. Copy to backend/.env and edit DATABASE_URL.
#
# DATABASE_URL format:
#   postgresql://USER[:PASSWORD]@HOST:PORT/DBNAME
#
# Common defaults:
#   - macOS + Homebrew Postgres: USER is your macOS username, no password.
#       postgresql://your-username@localhost:5432/coffeeshop
#   - Postgres.app / Linux: often USER=postgres, password depends on setup.
#       postgresql://postgres:postgres@localhost:5432/coffeeshop
#
# The database `coffeeshop` must exist before running migrations.
# Create it with:   createdb coffeeshop
DATABASE_URL="postgresql://USER@localhost:5432/coffeeshop"
PORT=3001
